  {
    "id": "757900a7-88ac-481a-8a72-0214cdd9e441",
    "type": "code",
    "content": "<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n<title>📋 لوحتي</title>\n<script src=\"https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js\"></script>\n<script src=\"https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore-compat.js\"></script>\n<script src=\"https://www.gstatic.com/firebasejs/10.12.0/firebase-storage-compat.js\"></script>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700&display=swap\" rel=\"stylesheet\">\n<style>\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\n:root{\n  --bg:#0d0d12;--surf:#16161f;--surf2:#1e1e2a;--border:#2a2a38;\n  --text:#e8e8f0;--muted:#6b6b82;--accent:#f59e0b;--accentD:rgba(245,158,11,.12);\n  --danger:#ef4444;--success:#22c55e;--r:12px\n}\nhtml,body{height:100%;overflow:hidden}\nbody{font-family:'Tajawal',system-ui,sans-serif;background:var(--bg);color:var(--text);display:flex;flex-direction:column}\n\n/* HEADER */\nheader{padding:13px 18px;background:var(--surf);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;gap:10px}\n.logo{font-size:17px;font-weight:700;letter-spacing:-.3px;display:flex;align-items:center;gap:8px}\n.logo em{color:var(--accent);font-style:normal}\n#dot{width:7px;height:7px;border-radius:50%;background:var(--muted);transition:background .3s,box-shadow .3s;flex-shrink:0}\n#dot.on{background:var(--success);box-shadow:0 0 7px var(--success)}\n#dot.err{background:var(--danger)}\n.hbtn{width:32px;height:32px;border-radius:9px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;transition:all .15s}\n.hbtn:hover{background:var(--surf2);color:var(--text)}\n\n/* CONFIG SCREEN */\n#cfg{flex:1;overflow-y:auto;padding:24px 16px;display:none;flex-direction:column;align-items:center;gap:18px}\n.card{width:100%;max-width:540px;background:var(--surf);border:1px solid var(--border);border-radius:var(--r);padding:20px}\n.step{display:flex;gap:12px;align-items:flex-start}\n.stepN{width:24px;height:24px;border-radius:50%;background:var(--accent);color:#000;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}\n.stepT{font-size:14px;font-weight:500;margin-bottom:3px}\n.stepD{font-size:13px;color:var(--muted);line-height:1.6}\n.stepD a{color:var(--accent);text-decoration:none}\n.lbl{font-size:12px;color:var(--muted);margin-bottom:5px}\n.inp{width:100%;padding:10px 13px;background:var(--bg);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:13px;font-family:monospace;transition:border .2s}\n.inp:focus{outline:none;border-color:var(--accent)}\n.btn{padding:12px 28px;background:var(--accent);color:#000;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;font-family:'Tajawal',sans-serif;transition:all .15s}\n.btn:hover{background:#fbbf24}\n.btn:active{transform:scale(.97)}\n\n/* CHAT SCREEN */\n#chat{flex:1;display:none;flex-direction:column;overflow:hidden;position:relative}\n\n/* DRAG */\n#drag{position:absolute;inset:0;background:rgba(245,158,11,.07);border:2px dashed var(--accent);z-index:100;display:none;align-items:center;justify-content:center;pointer-events:none;flex-direction:column;gap:12px}\n#drag.show{display:flex}\n#drag span{font-size:42px}\n#drag p{font-size:17px;font-weight:600;color:var(--accent)}\n\n/* MESSAGES */\n#msgs{flex:1;overflow-y:auto;padding:14px 14px 6px;display:flex;flex-direction:column;gap:7px;scroll-behavior:smooth}\n#msgs::-webkit-scrollbar{width:3px}\n#msgs::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}\n\n/* EMPTY */\n#empty{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;flex:1;color:var(--muted);font-size:14px;padding-bottom:40px}\n#empty span{font-size:44px;opacity:.25}\n\n/* BUBBLE */\n.msg{display:flex;flex-direction:column;align-items:flex-end;gap:3px;animation:in .2s ease}\n@keyframes in{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}\n.bbl{background:var(--surf);border:1px solid var(--border);border-radius:var(--r) var(--r) 4px var(--r);padding:10px 14px;max-width:min(86%,560px);word-break:break-word;position:relative}\n.bbl:hover~.acts,.bbl:hover+.acts,.acts:hover{opacity:1}\n.bbl-text{font-size:15px;line-height:1.65;white-space:pre-wrap}\n.bbl-text a{color:var(--accent);text-decoration:none}\n.bbl-text a:hover{text-decoration:underline}\n.bbl img{max-width:100%;max-height:300px;border-radius:8px;display:block;cursor:zoom-in}\n.bbl video{max-width:100%;max-height:300px;border-radius:8px;display:block}\n.bbl-fn{font-size:11px;color:var(--muted);margin-top:5px;font-family:monospace}\n.frow{display:flex;align-items:center;gap:11px;min-width:180px}\n.fico{width:40px;height:40px;border-radius:9px;background:var(--accentD);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}\n.fnam{font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px}\n.fsz{font-size:11px;color:var(--muted);font-family:monospace;margin-top:2px}\n.t{font-size:11px;color:var(--muted);padding:0 3px}\n\n/* ACTIONS */\n.acts{display:flex;gap:3px;opacity:0;transition:opacity .15s}\n.abtn{width:27px;height:27px;border-radius:7px;border:1px solid var(--border);background:var(--surf);color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;transition:all .15s}\n.abtn:hover{color:var(--text);background:var(--surf2);border-color:var(--accent)}\n.abtn.del:hover{color:var(--danger);border-color:var(--danger)}\n\n/* INPUT */\n#inparea{padding:10px 14px;background:var(--surf);border-top:1px solid var(--border);flex-shrink:0}\n.inprow{display:flex;align-items:flex-end;gap:7px;background:var(--bg);border:1px solid var(--border);border-radius:var(--r);padding:7px 7px 7px 12px;transition:border-color .2s}\n.inprow:focus-within{border-color:var(--accent)}\n#ti{flex:1;background:none;border:none;outline:none;color:var(--text);font-family:'Tajawal',sans-serif;font-size:15px;resize:none;max-height:110px;overflow-y:auto;line-height:1.5;padding:2px 0}\n#ti::placeholder{color:var(--muted)}\n.ibtn{width:35px;height:35px;border-radius:9px;border:1px solid var(--border);background:var(--surf);color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;transition:all .15s}\n.ibtn:hover{color:var(--text);background:var(--surf2)}\n#sbtn{background:var(--accent);color:#000;border:none}\n#sbtn:hover{background:#fbbf24}\n#sbtn:active{transform:scale(.95)}\n\n/* PROGRESS */\n.prog{background:var(--surf);border:1px solid var(--border);border-radius:var(--r);padding:10px 14px;align-self:flex-end;max-width:min(86%,560px)}\n.pbg{height:3px;background:var(--border);border-radius:2px;margin-top:7px;overflow:hidden}\n.pfill{height:100%;background:var(--accent);border-radius:2px;transition:width .2s}\n\n/* LIGHTBOX */\n#lb{position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:999;display:none;align-items:center;justify-content:center;cursor:zoom-out}\n#lb.show{display:flex}\n#lb img{max-width:95vw;max-height:95vh;border-radius:8px;object-fit:contain}\n\n/* TOAST */\n#toast{position:fixed;bottom:76px;left:50%;transform:translateX(-50%);background:var(--surf);border:1px solid var(--border);border-radius:100px;padding:7px 18px;font-size:13px;opacity:0;transition:opacity .2s;pointer-events:none;z-index:998;white-space:nowrap}\n#toast.show{opacity:1}\n\n@media(max-width:540px){.bbl{max-width:92%}}\n</style>\n</head>\n<body>\n\n<header>\n  <div class=\"logo\">📋 <em>لوحتي</em></div>\n  <div style=\"display:flex;align-items:center;gap:9px\">\n    <span id=\"stxt\" style=\"font-size:12px;color:var(--muted)\">—</span>\n    <div id=\"dot\"></div>\n    <button class=\"hbtn\" id=\"setbtn\" title=\"الإعدادات\">⚙️</button>\n  </div>\n</header>\n\n<!-- CONFIG -->\n<div id=\"cfg\">\n  <div style=\"text-align:center;max-width:540px\">\n    <div style=\"font-size:46px;margin-bottom:6px\">🔥</div>\n    <div style=\"font-size:21px;font-weight:700;color:var(--accent);margin-bottom:6px\">إعداد Firebase (مجاني)</div>\n    <div style=\"font-size:13px;color:var(--muted);line-height:1.7\">متزامن فوري بين كل أجهزتك · بياناتك لا تُحذف · مجاني تماماً</div>\n  </div>\n\n  <div class=\"card\" style=\"display:flex;flex-direction:column;gap:14px\">\n    <div style=\"font-size:15px;font-weight:600;margin-bottom:2px\">خطوات الإعداد (مرة واحدة فقط)</div>\n    <div class=\"step\">\n      <div class=\"stepN\">1</div>\n      <div><div class=\"stepT\">أنشئ مشروع Firebase</div>\n      <div class=\"stepD\">اذهب إلى <a href=\"https://console.firebase.google.com\" target=\"_blank\">console.firebase.google.com</a> ← New Project ← أي اسم</div></div>\n    </div>\n    <div class=\"step\">\n      <div class=\"stepN\">2</div>\n      <div><div class=\"stepT\">فعّل Firestore Database</div>\n      <div class=\"stepD\">Build ← Firestore Database ← Create database ← Start in <strong>test mode</strong></div></div>\n    </div>\n    <div class=\"step\">\n      <div class=\"stepN\">3</div>\n      <div><div class=\"stepT\">فعّل Storage</div>\n      <div class=\"stepD\">Build ← Storage ← Get started ← Start in <strong>test mode</strong></div></div>\n    </div>\n    <div class=\"step\">\n      <div class=\"stepN\">4</div>\n      <div><div class=\"stepT\">احصل على Config</div>\n      <div class=\"stepD\">Project Settings (⚙) ← Your apps ← أضف Web app (&lt;/&gt;) ← انسخ الـ config</div></div>\n    </div>\n  </div>\n\n  <div class=\"card\">\n    <div style=\"font-size:15px;font-weight:600;margin-bottom:14px\">الصق إعدادات Firebase</div>\n    <div style=\"display:flex;flex-direction:column;gap:10px\">\n      <div><div class=\"lbl\">apiKey</div><input class=\"inp\" id=\"c1\" placeholder=\"AIzaSy...\"></div>\n      <div><div class=\"lbl\">authDomain</div><input class=\"inp\" id=\"c2\" placeholder=\"myproject.firebaseapp.com\"></div>\n      <div><div class=\"lbl\">projectId</div><input class=\"inp\" id=\"c3\" placeholder=\"my-project-id\"></div>\n      <div><div class=\"lbl\">storageBucket</div><input class=\"inp\" id=\"c4\" placeholder=\"my-project.appspot.com\"></div>\n      <div><div class=\"lbl\">messagingSenderId</div><input class=\"inp\" id=\"c5\" placeholder=\"123456789012\"></div>\n      <div><div class=\"lbl\">appId</div><input class=\"inp\" id=\"c6\" placeholder=\"1:123456:web:abc123...\"></div>\n    </div>\n    <div style=\"margin-top:16px;display:flex;justify-content:flex-end\">\n      <button class=\"btn\" onclick=\"saveCfg()\">حفظ والبدء ←</button>\n    </div>\n  </div>\n  <div style=\"font-size:12px;color:var(--muted);text-align:center;max-width:400px;line-height:1.7\">\n    الإعدادات تُحفظ في متصفحك · كرر الخطوة في كل جهاز جديد\n    <br>لمشاركة نفس البيانات: فقط استخدم نفس الـ config في كل الأجهزة\n  </div>\n</div>\n\n<!-- CHAT -->\n<div id=\"chat\">\n  <div id=\"drag\"><span>📤</span><p>أفلت الملفات هنا</p></div>\n  <div id=\"msgs\">\n    <div id=\"empty\"><span>📋</span><div>لوحتك فارغة</div><div style=\"font-size:12px;margin-top:2px\">أرسل نص، صور، ملفات، فيديو...</div></div>\n  </div>\n  <div id=\"inparea\">\n    <div class=\"inprow\">\n      <textarea id=\"ti\" rows=\"1\" placeholder=\"اكتب... أو الصق صورة (Ctrl+V) أو اسحب ملف\"></textarea>\n      <label class=\"ibtn\" title=\"إرفاق ملف\" style=\"cursor:pointer\">\n        📎<input type=\"file\" id=\"fi\" multiple style=\"display:none\">\n      </label>\n      <button class=\"ibtn\" id=\"sbtn\" title=\"إرسال\">⬆</button>\n    </div>\n  </div>\n</div>\n\n<div id=\"lb\" onclick=\"closeLB()\"><img id=\"lbimg\" src=\"\" alt=\"\"></div>\n<div id=\"toast\"></div>\n\n<script>\nconst SK='fb_cfg_v2';\nlet db,stor,unsub;\n\n// ── CONFIG ──\nfunction loadCfg(){try{const r=localStorage.getItem(SK);return r?JSON.parse(r):null}catch{return null}}\n\nfunction saveCfg(){\n  const cfg={apiKey:g('c1'),authDomain:g('c2'),projectId:g('c3'),storageBucket:g('c4'),messagingSenderId:g('c5'),appId:g('c6')};\n  if(!cfg.apiKey||!cfg.projectId){toast('⚠️ أدخل apiKey و projectId');return}\n  localStorage.setItem(SK,JSON.stringify(cfg));\n  initFB(cfg);\n}\n\nfunction initFB(cfg){\n  try{\n    if(!firebase.apps.length)firebase.initializeApp(cfg);\n    db=firebase.firestore();stor=firebase.storage();\n    show('cfg',false);show('chat',true);\n    listen();setDot('on','متصل');\n  }catch(e){setDot('err','خطأ');toast('❌ تحقق من الإعدادات');console.error(e)}\n}\n\nfunction openCfg(){\n  const active=document.getElementById('chat').style.display!=='none';\n  show('chat',false);show('cfg',true);\n  const s=loadCfg();\n  if(s){g('c1').value=s.apiKey||'';g('c2').value=s.authDomain||'';g('c3').value=s.projectId||'';g('c4').value=s.storageBucket||'';g('c5').value=s.messagingSenderId||'';g('c6').value=s.appId||''}\n}\n\ndocument.getElementById('setbtn').onclick=()=>{\n  if(document.getElementById('chat').style.display!=='none'){show('chat',false);show('cfg',true);const s=loadCfg();if(s){g('c1').value=s.apiKey||'';g('c2').value=s.authDomain||'';g('c3').value=s.projectId||'';g('c4').value=s.storageBucket||'';g('c5').value=s.messagingSenderId||'';g('c6').value=s.appId||''}}\n  else{if(db){show('cfg',false);show('chat',true)}}\n};\n\n// ── REALTIME ──\nfunction listen(){\n  if(unsub)unsub();\n  unsub=db.collection('messages').orderBy('at','asc').onSnapshot(snap=>{\n    render(snap.docs.map(d=>({id:d.id,...d.data()})));\n  },e=>{setDot('err','انقطع الاتصال');console.error(e)});\n}\n\n// ── RENDER ──\nfunction render(list){\n  const area=document.getElementById('msgs');\n  const atBot=area.scrollHeight-area.scrollTop<=area.clientHeight+100;\n  const emp=document.getElementById('empty');\n  area.innerHTML='';\n  if(!list.length){area.appendChild(emp);return}\n  list.forEach(m=>area.appendChild(mkBubble(m)));\n  if(atBot)area.scrollTop=area.scrollHeight;\n}\n\nfunction mkBubble(m){\n  const w=ce('div');w.className='msg';w.dataset.id=m.id;\n  const b=ce('div');b.className='bbl';\n\n  if(m.tp==='text'){\n    const d=ce('div');d.className='bbl-text';d.innerHTML=linkify(esc(m.v));b.appendChild(d);\n  } else if(m.tp==='img'){\n    const img=ce('img');img.src=m.url;img.alt=esc(m.n||'');img.loading='lazy';\n    img.onclick=()=>openLB(m.url);b.appendChild(img);\n    if(m.n){const fn=ce('div');fn.className='bbl-fn';fn.textContent=m.n;b.appendChild(fn)}\n  } else if(m.tp==='vid'){\n    const v=ce('video');v.src=m.url;v.controls=true;v.preload='metadata';b.appendChild(v);\n    if(m.n){const fn=ce('div');fn.className='bbl-fn';fn.textContent=m.n;b.appendChild(fn)}\n  } else if(m.tp==='file'){\n    const row=ce('div');row.className='frow';\n    const ico=ce('div');ico.className='fico';ico.textContent=ficon(m.n);\n    const info=ce('div');info.style.flex='1';info.style.minWidth='0';\n    const nm=ce('div');nm.className='fnam';nm.textContent=m.n||'ملف';\n    const sz=ce('div');sz.className='fsz';sz.textContent=fsize(m.sz);\n    info.appendChild(nm);info.appendChild(sz);\n    row.appendChild(ico);row.appendChild(info);b.appendChild(row);\n  }\n\n  // Actions\n  const acts=ce('div');acts.className='acts';\n  if(m.tp!=='text'){\n    const dl=mkBtn('⬇','تحميل',()=>dlFile(m.url,m.n));acts.appendChild(dl);\n  }\n  if(m.tp==='text'){\n    const cp=mkBtn('📋','نسخ',()=>{navigator.clipboard.writeText(m.v);toast('تم النسخ ✓')});acts.appendChild(cp);\n  }\n  if(m.tp==='img'){\n    const cp=mkBtn('🔗','نسخ الرابط',()=>{navigator.clipboard.writeText(m.url);toast('تم نسخ الرابط ✓')});acts.appendChild(cp);\n  }\n  const dl2=mkBtn('🗑','حذف',()=>delMsg(m.id,m.sp),'del');acts.appendChild(dl2);\n\n  const t=ce('div');t.className='t';t.textContent=m.at?fmtTime(m.at.toDate()):'...';\n\n  w.appendChild(b);w.appendChild(acts);w.appendChild(t);\n  return w;\n}\n\nfunction mkBtn(icon,title,fn,cls=''){\n  const b=ce('button');b.className='abtn'+(cls?' '+cls:'');b.title=title;b.textContent=icon;b.onclick=fn;return b;\n}\n\n// ── SEND ──\nasync function sendText(){\n  const ti=document.getElementById('ti');\n  const v=ti.value.trim();if(!v)return;\n  ti.value='';ti.style.height='auto';\n  await db.collection('messages').add({tp:'text',v,at:firebase.firestore.FieldValue.serverTimestamp()});\n}\n\nasync function upload(file){\n  const isImg=file.type.startsWith('image/');\n  const isVid=file.type.startsWith('video/');\n  const tp=isImg?'img':isVid?'vid':'file';\n  const path=`f/${Date.now()}_${file.name}`;\n  const ref=stor.ref(path);\n\n  // Progress indicator\n  const pid='p'+Date.now();\n  const area=document.getElementById('msgs');\n  const pel=ce('div');pel.id=pid;pel.className='prog';\n  pel.innerHTML=`<div style=\"font-size:13px;color:var(--muted)\">⬆ ${esc(file.name)}</div><div class=\"pbg\"><div class=\"pfill\" id=\"${pid}b\" style=\"width:0%\"></div></div>`;\n  area.appendChild(pel);area.scrollTop=area.scrollHeight;\n\n  const task=ref.put(file);\n  task.on('state_changed',s=>{\n    const pct=(s.bytesTransferred/s.totalBytes*100).toFixed(0);\n    const bar=document.getElementById(pid+'b');if(bar)bar.style.width=pct+'%';\n  });\n  await task;\n  const url=await ref.getDownloadURL();\n  pel.remove();\n\n  await db.collection('messages').add({tp,n:file.name,sz:file.size,url,sp:path,at:firebase.firestore.FieldValue.serverTimestamp()});\n}\n\nasync function delMsg(id,sp){\n  await db.collection('messages').doc(id).delete();\n  if(sp){try{await stor.ref(sp).delete()}catch(e){}}\n}\n\n// ── INPUT WIRING ──\nconst ti=document.getElementById('ti');\nti.addEventListener('input',()=>{ti.style.height='auto';ti.style.height=Math.min(ti.scrollHeight,110)+'px'});\nti.addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendText()}});\ndocument.getElementById('sbtn').onclick=sendText;\ndocument.getElementById('fi').onchange=e=>{[...e.target.files].forEach(upload);e.target.value=''};\n\n// Paste image\ndocument.addEventListener('paste',e=>{\n  if(!db)return;\n  const items=[...(e.clipboardData?.items||[])];\n  items.forEach(it=>{\n    if(it.type.startsWith('image/')){\n      const f=it.getAsFile();\n      if(f)upload(new File([f],`paste_${Date.now()}.png`,{type:f.type}));\n    }\n  });\n});\n\n// Drag & drop\nconst chat=document.getElementById('chat');\nconst drag=document.getElementById('drag');\nlet dc=0;\nchat.addEventListener('dragenter',e=>{e.preventDefault();dc++;drag.classList.add('show')});\nchat.addEventListener('dragleave',()=>{dc--;if(dc<=0){dc=0;drag.classList.remove('show')}});\nchat.addEventListener('dragover',e=>e.preventDefault());\nchat.addEventListener('drop',e=>{\n  e.preventDefault();dc=0;drag.classList.remove('show');\n  if(!db)return;\n  [...e.dataTransfer.files].forEach(upload);\n});\n\n// ── LIGHTBOX ──\nfunction openLB(url){document.getElementById('lbimg').src=url;document.getElementById('lb').classList.add('show')}\nfunction closeLB(){document.getElementById('lb').classList.remove('show')}\n\n// ── UTILS ──\nfunction g(id){return document.getElementById(id)}\nfunction ce(tag){return document.createElement(tag)}\nfunction show(id,on){const el=document.getElementById(id);if(on){el.style.display='flex';if(id==='chat')el.style.flexDirection='column'}else{el.style.display='none'}}\nfunction setDot(s,t){document.getElementById('dot').className=s==='on'?'on':s==='err'?'err':'';document.getElementById('stxt').textContent=t}\nfunction toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2200)}\nfunction fmtTime(d){const n=new Date();const t=d.toLocaleTimeString('ar',{hour:'2-digit',minute:'2-digit'});return d.toDateString()===n.toDateString()?t:d.toLocaleDateString('ar',{month:'short',day:'numeric'})+' '+t}\nfunction fsize(b){if(!b)return'';if(b<1024)return b+' B';if(b<1048576)return(b/1024).toFixed(1)+' KB';return(b/1048576).toFixed(1)+' MB'}\nfunction esc(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;')}\nfunction linkify(t){return t.replace(/(https?:\\/\\/[^\\s<]+)/g,'<a href=\"$1\" target=\"_blank\" rel=\"noopener\">$1</a>')}\nfunction ficon(n){if(!n)return'📄';const e=n.split('.').pop().toLowerCase();return{pdf:'📕',doc:'📝',docx:'📝',xls:'📊',xlsx:'📊',ppt:'📑',pptx:'📑',zip:'🗜',rar:'🗜','7z':'🗜',mp3:'🎵',wav:'🎵',aac:'🎵',ogg:'🎵',mp4:'🎬',mov:'🎬',avi:'🎬',mkv:'🎬',txt:'📄',json:'🔧',js:'🔧',ts:'🔧',py:'🔧',cs:'🔧',html:'🌐',css:'🎨',apk:'📱',exe:'💾',dmg:'💾',ipa:'📱'}[e]||'📄'}\nfunction dlFile(url,name){const a=ce('a');a.href=url;a.download=name||'file';a.target='_blank';a.click()}\n\n// ── INIT ──\nconst HARDCODED_CFG={\n  apiKey:\"AIzaSyBMENtf0HFGI8vgUXwT4sJoncKUvt8oRb8\",\n  authDomain:\"fareed-07.firebaseapp.com\",\n  projectId:\"fareed-07\",\n  storageBucket:\"fareed-07.firebasestorage.app\",\n  messagingSenderId:\"990039730269\",\n  appId:\"1:990039730269:web:248ee431b366ec8cbc05b4\"\n};\nlocalStorage.setItem(SK,JSON.stringify(HARDCODED_CFG));\ninitFB(HARDCODED_CFG);\n</script>\n</body>\n</html>\n\n",
